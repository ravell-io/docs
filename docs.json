{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ravell",
  "mode": "light",
  "modeToggle": {
    "default": "light",
    "isHidden": true
  },
  "appearance": {
    "strict": true
  },
  "colors": {
    "primary": "#18181b",
    "light": "#155dfc",
    "dark": "#084de2"
  },
  "favicon": "/favicon.svg",
  "logo": "/logo/light.svg",
  "tabs": [
    { "tab": "Use Cases", "href": "/use-cases/product-managers" },
    { "tab": "Admin & Reference", "href": "/workspace-setup" }
  ],
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["index", "quickstart", "first-week"]
      },
      {
        "group": "Asking Questions",
        "pages": ["asks", "better-questions", "scoping-queries"]
      },
      {
        "group": "Slack Agent",
        "pages": ["slack-agent"]
      },
      {
        "group": "Agents & Inbox",
        "pages": ["agents", "agent-templates", "inbox"]
      },
      {
        "group": "Integrations",
        "pages": [
          "sources",
          "integrations/linear",
          "integrations/notion",
          "integrations/intercom",
          "integrations/slack",
          "integrations/attio"
        ]
      },
      {
        "group": "Personalization",
        "pages": ["context", "profiles", "memory"]
      },
      {
        "group": "How Ravell Works",
        "pages": ["system-overview", "knowledge-graph", "security-privacy"]
      },
      {
        "group": "By Role",
        "tab": "Use Cases",
        "pages": [
          "use-cases/product-managers",
          "use-cases/engineering-leads",
          "use-cases/customer-success",
          "use-cases/founders"
        ]
      },
      {
        "group": "Scenarios",
        "tab": "Use Cases",
        "pages": [
          "use-cases/standup-prep",
          "use-cases/feedback-analysis",
          "use-cases/sprint-review",
          "use-cases/product-roundup"
        ]
      },
      {
        "group": "Question Library",
        "tab": "Use Cases",
        "pages": ["use-cases/question-library"]
      },
      {
        "group": "Administration",
        "tab": "Admin & Reference",
        "pages": [
          "workspace-setup",
          "workspace-management",
          "billing",
          "visibility-sharing"
        ]
      },
      {
        "group": "Reference",
        "tab": "Admin & Reference",
        "pages": ["shortcuts", "glossary"]
      },
      {
        "group": "Developer",
        "tab": "Admin & Reference",
        "pages": ["api-keys", "knowledge-api", "mcp"]
      },
      {
        "group": "Help",
        "tab": "Admin & Reference",
        "pages": ["help/faq", "help/troubleshooting"]
      }
